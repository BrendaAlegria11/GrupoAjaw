---
import MainLayout from "../layouts/MainLayout.astro";
import Contacto from "../components/Contacto.astro";
import Seccion1 from "../pages/sections/seccion1.astro";
import Seccion2 from "./sections/seccion2.astro";
import Seccion3 from "./sections/seccion3.astro";
import Seccion4 from "../pages/sections/seccion4.astro";
import Seccion5 from "./sections/seccion5.astro";
import heroImage from "../assets/inicio/fondoinicio.png";
---

<MainLayout>
  <section
    class="relative h-[75vh] lg:min-h-screen overflow-hidden border border"
  >
    <!-- Fondo -->
    <div class="absolute inset-0">
      <img
        src={heroImage.src}
        alt="Equipo"
        class="w-full h-full object-cover"
      />
    </div>

    <!-- Cortina oscura -->
    <div class="absolute inset-0 bg-black/60 lg:bg-transparent"></div>

    <!-- Contenido -->
    <div
      class="relative z-10 max-w-7xl mx-auto h-full flex items-center justify-center lg:justify-start w-4/5"
    >
      <div class="text-white">
        <h1 class="text-5xl md:text-6xl font-bold mt-20 mb-6">
          Experiencia e
          <br />
          innovación en <br class="hidden lg:block" /> acción.
        </h1>

        <p class="text-base md:text-xl font-mediumtext-gray-300 max-w-md mb-10">
          Impulsamos el crecimiento de nuestros clientes con tecnología y
          talento especializado.
        </p>
        <a
          href="#"
          class="inline-flex items-center justify-center
         px-6 py-3 lg:px-10 lg:py-4
         border border-white
         rounded-full
         text-base lg:text-lg font-semibold
         hover:bg-white hover:text-[#001133]
         transition-all duration-300"
        >
          Conoce más
        </a>
      </div>
    </div>
  </section>

  <!--SECCION 1  -->
  <Seccion1 />

  <!--SECCION 2  -->
  <Seccion2 />

  <!--SECCION 3  -->
  <Seccion3 />

  <!--SECCION 4  -->
  <Seccion4 />

  <!--SECCION 5  -->
  <Seccion5 />

  <!--SECCION CONTACTO -->
  <Contacto />
</MainLayout>
