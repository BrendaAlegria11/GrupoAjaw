---
import img from "../../assets/seccion4/img.png";
import imgMobile from "../../assets/seccion4/imgMobile.png";
---

<section class="flex flex-col items-center pb-4 md:pb-0">
    <div class="w-4/5">
        <h1 class="slideRight animar text-titulos font-bold text-2xl md:text-4xl text-center md:text-end mb-5">
            ¿Por qué trabajar con Grupo Ajaw Ingeniería?
        </h1>
        <p class="scale animar text-textos text-base font-medium md:text-xl text-center md:text-end" >
            No solo ejecutamos proyectos. Construimos soluciones<br /> estratégicas
            adaptadas a cada necesidad.
        </p>
    </div>
    <!-- ESCRITORIO -->
    <div class="hidden md:block bg-[url('../assets/seccion4/fondo.png')] bg-cover bg-center h-140 w-full relative mt-10">
        <img src={img.src} alt="" class="zoom animar absolute -top-8 left-45 z-10 w-290" />
    </div>

    <!-- MÓVIL -->
    <div class="block md:hidden bg-[url('../assets/seccion4/fondomobile.png')] bg-cover bg-center h-128 w-full relative mt-10">
        <img src={imgMobile.src} alt="" class="w-82 h-130 mx-auto mt-4" />
    </div>

    
</section>
