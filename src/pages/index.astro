---
import MainLayout from "../layouts/MainLayout.astro";
import Seccion1 from "../pages/sections/seccion1.astro"; 
import Seccion4 from "../pages/sections/seccion4.astro"; 


import heroImage from "../assets/inicio/fondoinicio.png";

import Seccion2 from "./sections/seccion2.astro";
import Seccion3 from "./sections/seccion3.astro";
import Seccion5 from "./sections/seccion5.astro";
---

<MainLayout>

<section class="relative min-h-screen overflow-hidden border border">

  <!-- Fondo -->
  <div class="absolute inset-0">
    <img
      src={heroImage.src}
      alt="Equipo"
      class="w-full h-full object-cover"
    />
  </div>


  <!-- Contenido -->
  <div class="relative z-10 max-w-7xl mx-auto px-2 min-h-screen flex items-center">
    <div class="w-full lg:w-1/2 text-white">
      <h1 class="text-5xl md:text-6xl font-bold leading-tight mb-6">
        Experiencia e
        <br />
        innovación en
        <br />
        acción.
      </h1>

      <p class="text-lg text-gray-300 max-w-md mb-10">
        Impulsamos el crecimiento de nuestros clientes con
        tecnología y talento especializado.
      </p>
      <a
        href="#"
        class="inline-flex items-center justify-center
               px-10 py-4
               border border-white
               rounded-full
               text-lg font-semibold
               hover:bg-white hover:text-[#001133]
               transition-all duration-300"
      >
        Conoce más
      </a>
    </div>
  </div>

  

</section>




<!--SECCION 1  -->
<Seccion1></Seccion1>
<Seccion2 />
<Seccion3 />
<!--SECCION 4  -->
<Seccion4></Seccion4>
<Seccion5 />
</MainLayout>