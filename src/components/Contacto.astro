---
import imagen1 from "../assets/contacto/imagen1.png";
import imagen2 from "../assets/contacto/imagen2.png";
import info from "../assets/contacto/imagen-info.png";
import icon1 from "../assets/contacto/icon1.png";
import icon2 from "../assets/contacto/icon2.png";
import icon3 from "../assets/contacto/icon3.png";
---


<section class="flex justify-center relative w-full overflow-hidden">
    <img src={imagen1.src} class="absolute top-0 left-0 z-0 w-20 md:w-64 pointer-events-none" />
    <img src={imagen2.src} class="absolute top-0 right-100 z-0 w-20 md:w-30 pointer-events-none" />


    <div class="w-4/5 relative z-10 mt-10 md:mt-0 md:mb-20">
        <h1 class="text-titulos text-2xl md:text-4xl font-bold py-5 md:py-20">CONTÁCTANOS AHORA</h1>
        <p id="formResponse" class="text-center text-sm font-semibold hidden py-2"></p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <form id="contactForm" class="grid grid-cols-1 md:grid-cols-2 gap-2">
                <div>
                    <input
                        type="text"
                        placeholder="Nombre"
                        id="nombre"
                        name="nombre"
                        required
                        class="w-full p-3 border border-titulos rounded-md text-titulos">
                </div>

                <div>
                    <input
                        type="text"
                        placeholder="Empresa"
                        id="empresa"
                        name="empresa"
                        class="w-full p-3 border border-titulos rounded-md text-titulos">
                </div>

                <div>
                    <input
                        type="tel"
                        placeholder="Teléfono"
                        id="telefono"
                        name="telefono"
                        class="w-full p-3 border border-titulos rounded-md text-titulos">
                </div>

                <div>
                    <input
                        type="email"
                        placeholder="Correo electrónico"
                        id="correo"
                        name="correo"
                        required
                        class="w-full p-3 border border-titulos rounded-md text-titulos">
                </div>

                <div class="md:col-span-2">
                    <textarea
                        placeholder="Cuéntanos sobre tu proyecto"
                        rows="5"
                        id="mensaje"
                        name="mensaje"
                        required
                        class="w-full p-3 border border-titulos rounded-md text-titulos">
                    </textarea>
                </div>

                <div class="md:col-span-2">
                    <button type="submit" class="w-full p-3 text-center text-white   uppercase font-bold bg-titulos">
                    Enviar información
                    </button>
                </div>
            </form>
    
            <div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center relative">
                        
                    <!-- Tarjeta de Contacto -->
                    <div class="border border-titulos p-8 md:p-12 md:mr-[-4rem] rounded-l-lg z-10">
                    <div class="space-y-6 text-titulos">
                        
                            <!-- Llámanos -->
                        <div class="flex items-center gap-4">
                            <img src={icon1.src} alt="" class="w-6 h-6">
                            <div>
                                <h3 class="font-bold text-lg">Llámanos</h3>
                                <p class="text-sm opacity-90">+52 442 454 0557</p>
                            </div>
                        </div>

                        <!-- Escríbenos -->
                        <div class="flex items-center gap-4">
                            <img src={icon2.src} alt="" class="w-6 h-6">
                            <div>
                                <h3 class="font-bold text-lg">Escríbenos</h3>
                                <p class="text-sm opacity-90">contacto@ajaw.com.mx</p>
                            </div>
                        </div>

                        <!-- Horario -->
                        <div class="flex items-center gap-4">
                            <img src={icon3.src} alt="" class="w-6 h-6">
                            <div>
                                <h3 class="font-bold text-lg">Horario</h3>
                                <p class="text-sm opacity-90">Lunes a Viernes</p>
                                <p class="text-sm opacity-90">09:00am - 06:00pm</p>
                            </div>
                        </div>
                        
                    </div>
                    </div>

                    <div class="w-[300px] h-[20px] right-0 min-h-[370px] z-20 md:absolute mb-10 md:mb-0">
                    <img 
                        src={info.src}
                        alt="Trabajador" 
                        class="w-full h-full object-cover rounded-2xl shadow-md"
                    />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<script>
    document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contactForm') as HTMLFormElement;
    const responseMessage = document.getElementById('formResponse');

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const checkboxes = document.querySelectorAll('input[name="servicios[]"]:checked') as NodeListOf<HTMLInputElement>;

        const formData = {
            nombre: (document.getElementById('nombre') as HTMLInputElement).value,
            empresa: (document.getElementById('empresa') as HTMLInputElement).value,
            telefono: (document.getElementById('telefono') as HTMLInputElement).value,
            correo: (document.getElementById('correo') as HTMLInputElement).value,
            mensaje: (document.getElementById('mensaje') as HTMLTextAreaElement).value,
        };

        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        if (submitBtn) submitBtn.disabled = true;

        if (responseMessage) {
            responseMessage.classList.remove('hidden');
            responseMessage.style.color = '#c084fc';
            responseMessage.textContent = 'Enviando información...';
        }

        try {
            const response = await fetch('/enviar.php', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(formData),
            });

            if (!response.ok) {
            throw new Error('Error en la respuesta del servidor');
            }

            const result = await response.json();

            if (responseMessage) {
            if (result.status === 'success') {
                responseMessage.style.color = '#22c55e';
                responseMessage.innerHTML =  `<i class="fa-solid fa-circle-check mr-2"></i> ¡Mensaje recibido con éxito! <br/> Pronto nos comunicaremos contigo para conocer tu proyecto.`;
                form.reset();
            } else {
                responseMessage.style.color = '#ef4444';
            }
            }
        } catch (error) {
            if (responseMessage) {
            responseMessage.style.color = '#ef4444';
            responseMessage.innerHTML =  `<i class="fa-solid fa-circle-exclamation mr-2"></i> Hubo un error, intentalo de nuevo o contactanos por Whatsapp. `;
            }
        } finally {
            if (submitBtn) submitBtn.disabled = false;
        }
        });
    });
</script>