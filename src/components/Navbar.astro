---
import logo from "../assets/nav/logo.png";
---
<header class="fixed top-0 left-0 w-full z-50 bg-[#F3F1F3] shadow-sm">

  <!-- Desktop -->
  <nav class="hidden lg:block">
    <div class="max-w-7xl mx-auto px-10">
      <div class="flex items-center justify-between h-24">

        <div class="flex items-center gap-40">
          <a href="/" class="text-titulos font-semibold hover:text-textos transition">
            INICIO
          </a>

          <a href="https://ajaw.com.mx/conocenos" class="text-titulos font-semibold hover:text-textos transition">
            NOSOTROS
          </a>
        </div>

        <div class="absolute left-1/2 -translate-x-1/2">
          <img
            src={logo.src}
            class="h-16"
            alt="Logo"
          />
        </div>

        <div class="flex items-center gap-40">
          <a 
            href="https://www.ajaw.com.mx/bepartner"
            target="_blank"
            rel="noopener noreferrer"
            class="text-titulos font-semibold hover:text-textos transition">
            BE PARTNER
          </a>

          <a
            href="https://www.ajaw.com.mx/app"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-titulos text-white px-8 py-3 rounded-full font-bold hover:scale-105 transition"
          >
            APP
          </a>
        </div>

      </div>
    </div>
  </nav>

  <!-- Mobile -->
  <nav class="lg:hidden">

     <!-- Barra -->
    <div class="flex justify-center items-center h-24 bg-[#F3F1F3] relative z-50">

        <button id="menuBtn">
            <img
                src={logo.src}
                alt="Logo"
                id="logoMenu"
                class="h-14 transition duration-500"
            />
        </button>

      </div>

    <!-- Menú Fullscreen -->
    <div id="mobileMenu"
        class="fixed inset-0 bg-[#F3F1F3] z-40
        flex flex-col justify-center items-center
        translate-y-[-100%]
        transition-transform duration-700 ease-in-out"
    >

        <div class="flex flex-col items-center gap-10">

            <a href="/" class="text-2xl font-medium text-titulos">
                INICIO
            </a>

            <a href="/nosotros" class="text-2xl font-medium text-titulos">
                NOSOTROS
            </a>

            <a href="/partner" class="text-2xl font-medium text-titulos">
                BE PARTNER
            </a>

            <a
                href="/app"
                class="bg-titulos text-white px-10 py-4 rounded-full text-2xl font-medium"
            >
                APP
            </a>

            <div class="flex gap-8 text-3xl text-titulos mt-10">

                <i class="fa-brands fa-instagram"></i>
                <i class="fa-brands fa-facebook"></i>

            </div>

        </div>

    </div>
  </nav>

</header>
<script is:inline>
document.addEventListener("DOMContentLoaded", () => {
  const btn = document.getElementById("menuBtn");
  const menu = document.getElementById("mobileMenu");
  const logo = document.getElementById("logoMenu");

  if (!btn || !menu || !logo) return;

  let abierto = false;

  btn.addEventListener("click", () => {
    abierto = !abierto;

    if (abierto) {
      menu.classList.remove("translate-y-[-100%]");
      menu.classList.add("translate-y-0");

      logo.classList.add("scale-110");

      document.body.style.overflow = "hidden";
    } else {
      menu.classList.remove("translate-y-0");
      menu.classList.add("translate-y-[-100%]");

      logo.classList.remove("scale-110");

      document.body.style.overflow = "";
    }
  });
});
</script>